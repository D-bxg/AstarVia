{
  "name": "astarvia-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm.cmd run build:web && npm.cmd run build:electron",
    "preview": "vite preview",
    "electron:dev": "npm.cmd run build && npx electron .",
    "dist:win": "npm.cmd run build && npx electron-builder --win portable"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.170.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/drei": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.astarvia.app",
    "productName": "AstarVia",
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "electron/*.js",
      "dist/web/**"
    ],
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "AstarVia.exe"
    }
  }
}
